<?xml version="1.0"?>

<!-- NuGraph Production TEST: stage0 ROOT -> stage1 (NuGraphReco) -> flat CAF
     Release:  v10_06_00_04p04
     Test run: 1 job, 1 file, ~20 events
     Author:   sdey2
-->

<!DOCTYPE project [
<!ENTITY release       "v10_06_00_04p04" >
<!ENTITY file_type     "mc"  >
<!ENTITY run_type      "bnb"   >
<!ENTITY name          "BNB_NuGraph_v10_06_00_04p04_test">
<!ENTITY nevents       "100000">
<!ENTITY scratch_dir   "/pnfs/icarus/scratch/users/sdey2/v10_06_00_04p04/nugraph">
<!ENTITY resilient_dir "/pnfs/icarus/resilient/users/sdey2">
]>

<job>

  <project name="&name;">

    <!-- Project size -->
    <numevents>&nevents;</numevents>

    <!-- Operating System -->
    <os>SL7</os>

    <!-- Batch resources -->
    <resource>DEDICATED,OPPORTUNISTIC</resource>

    <larsoft>
      <tag>&release;</tag>
      <qual>e26:prof</qual>
      <local>&resilient_dir;/tarballs/icaruscode-workingarea-v10_06_00_04p04_nugraph.tar.gz</local>
    </larsoft>

    <!-- ============================================================
         STAGE 1: stage0 ROOT -> stage1 NuGraph reconstruction
         ============================================================ -->
    <stage name="stage1">
      <fcl>stage1_run2_icarus_overlay_NuGraphReco.fcl</fcl>

      <outdir>&scratch_dir;/&name;/stage1/5000</outdir>
      <workdir>&resilient_dir;/workdirs/&name;/stage1/5000</workdir>
      <logdir>&scratch_dir;/&name;/stage1/5000</logdir>
      <bookdir>&scratch_dir;/&name;/stage1/5000</bookdir>

      <numjobs>5000</numjobs>
      <maxfilesperjob>1</maxfilesperjob>
      <inputlist>/exp/icarus/app/users/sdey2/fileLists/BNBstage0_v10_06_00_04p04_MCOverlays2025A.list</inputlist>

      <datatier>reconstructed</datatier>
      <memory>12000</memory>
      <disk>100GB</disk>
      <jobsub>--expected-lifetime=12h --generate-email-summary -l +SingularityImage="/cvmfs/singularity.opensciencegrid.org/fermilab/fnal-wn-sl7:latest" --append_condor_requirements='(TARGET.HAS_SINGULARITY=?=true)'</jobsub>
    </stage>

    <!-- ============================================================
         CAF STAGE: stage1 ROOT -> flat CAF
         After stage1 completes, run:
           project.py xml <this_file> stage stage1 check
         then update the inputlist below with the generated files.list path:
           /pnfs/icarus/scratch/users/sdey2/v10_06_00_04p04/nugraph/BNB_NuGraph_v10_06_00_04p04_test/stage1/files.list
         ============================================================ -->
    <stage name="caf">
      <fcl>cafmakerjob_icarus_detsim2d_systtools_and_fluxwgt_overlay_NuGraphReco.fcl</fcl>

      <outdir>&scratch_dir;/&name;/caf</outdir>
      <workdir>&resilient_dir;/workdirs/&name;/caf</workdir>
      <logdir>&scratch_dir;/&name;/caf</logdir>
      <bookdir>&scratch_dir;/&name;/caf</bookdir>

      <numjobs>5000</numjobs>
      <maxfilesperjob>1</maxfilesperjob>
      <inputlist>/pnfs/icarus/scratch/users/sdey2/v10_06_00_04p04/nugraph/BNB_NuGraph_v10_06_00_04p04_test/stage1/files.list</inputlist>

      <datatier>reconstructed</datatier>
      <memory>8000</memory>
      <disk>50GB</disk>
      <jobsub>--expected-lifetime=12h --generate-email-summary -l +SingularityImage="/cvmfs/singularity.opensciencegrid.org/fermilab/fnal-wn-sl7:latest" --append_condor_requirements='(TARGET.HAS_SINGULARITY=?=true)' --env FW_SEARCH_PATH=/pnfs/icarus/resilient/users/sdey2/nugraph_models:${FW_SEARCH_PATH}</jobsub>
    </stage>

    <!-- file type -->
    <filetype>&file_type;</filetype>

    <!-- run type -->
    <runtype>&run_type;</runtype>

  </project>

</job>
